#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -x "$basedir/-u" ]; then
  exec "$basedir/-u" DEBUG node "$basedir/../ja/cli/ja.js" "$@"
else 
  exec -u DEBUG node "$basedir/../ja/cli/ja.js" "$@"
fi

{
  "name": "antigravity-cli",
  "version": "0.0.1",
  "description": "Antigravity CLI - placeholder",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "kirox": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "lint:knip": "knip",
    "lint:all": "npm run lint && npm run lint:knip",
    "knip": "knip",
    "format": "prettier --write \"src/**/*.ts\"",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "bumpp": "bumpp"
  },
  "keywords": [
    "cli",
    "gemini-3",
    "antigravity",
    "github",
    "fetch",
    "cc-sdd"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
  },
  "devDependencies": {
  }
}
